generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Produto {
  id Int @id @default(autoincrement())
  nome String
  descricao String
  preco Decimal @db.Decimal(10,2) @default(0)
  categoria String
  imagem Int
  itensPedido ItemPedido[]
}

model Pedido {
  id Int @id @default(autoincrement())
  dataCriacao DateTime @default(now())
  status String @default("PENDENTE") // pendente, preparando, entregue, cancelado
  total Decimal @db.Decimal(10,2) @default(0)
  numeroPedido Int @default(autoincrement())
  itens ItemPedido[]
}

model ItemPedido {
  id Int @id @default(autoincrement())
  pedidoId Int
  produtoId Int
  quantidade Int
  precoUnit Decimal @db.Decimal(10,2)

  pedido Pedido @relation(fields: [pedidoId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])
}

